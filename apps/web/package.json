{
  "name": "@doom-like/web",
  "version": "0.1.0",
  "private": true,
  "description": "Web application for the DOOM-like game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit", 
    "lint": "biome check .",
    "format": "biome format . --write"
  },
  "dependencies": {
    "@doom-like/engine": "workspace:*",
    "@doom-like/game-logic": "workspace:*",
    "@doom-like/map-editor": "workspace:*",
    "@doom-like/assets": "workspace:*",
    "@babylonjs/core": "^7.0.0",
    "@babylonjs/materials": "^7.0.0",
    "@babylonjs/loaders": "^7.0.0",
    "@babylonjs/gui": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@types/node": "^20.14.0",
    "playwright": "^1.45.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}